#: AppRun:11
msgid ""
"Drag a file or directory onto Archive to archive it. Drag an archive onto it "
"to extract."
msgstr ""
"Trascinare un file o una directory su «Archive» per creare un archivio. "
"Trascinarci sopra un archivio per estrarlo."

#: AppRun:22
msgid "Sorry, I can only extract/archive local files."
msgstr "È possibile archiviare/estrarre solo file locali."

#: box.py:34
msgid "Delete file afterwards?"
msgstr "Eliminare il file alla fine"

#: formats.py:46
msgid "Compress as .%s"
msgstr "Comprimi come .%s"

#: formats.py:57
msgid "Decompress .%s"
msgstr "Decomprimi .%s"

#: formats.py:69
msgid "Extract from a .%s"
msgstr "Estrai da un .%s"

#: formats.py:72
msgid ""
"This operation creates a directory, so you have to drag to a filer window on "
"the local machine"
msgstr ""
"Questa operazione crea una directory che va poi trascinata su una finestra "
"del filer della sistema locale"

#: formats.py:78
msgid "'%s' already exists and is not a directory!"
msgstr "«%s» esiste già e non è una directory."

#: formats.py:126
msgid "Create .%s archive"
msgstr "Crea un archivio .%s"

#: support.py:10
msgid "Sorry, this version of Archive requires ROX-Lib 1.9.3 or later"
msgstr "Questa versione di «Archive» richiede ROX-Lib 1.9.3 o superiore"

#: support.py:20
msgid "Operation aborted at user's request"
msgstr "Operazione interrotta su richiesta dell'utente"

#: support.py:114
msgid ""
"Errors from command '%s':\n"
"%s"
msgstr ""
"Errori dal comando «%s»:\n"
"%s"

#: support.py:116
msgid "Command '%s' returned an error code!"
msgstr "Il comando «%s» ha restituito un codice di errore."
