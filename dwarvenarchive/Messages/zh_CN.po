#: AppRun:12
msgid ""
"Drag a file or directory onto Archive to archive it. Drag an archive onto it "
"to extract."
msgstr "把文件或目录拖放进 Archive 以压缩. 亦可将压缩档拖放进以解压"

#: AppRun:23
msgid "Sorry, I can only extract/archive local files."
msgstr "只可解压或压缩本机的文件."

#: box.py:42
msgid "_Delete file afterwards?"
msgstr "完成后删除文件?(_D)"

#: formats.py:47
msgid "Compress as .%s"
msgstr "将目标压缩为 .%s"

#: formats.py:58
msgid "Decompress .%s"
msgstr "将目标解压 .%s"

#: formats.py:70
msgid "Extract from a .%s"
msgstr "解压出文件从 .%s"

#: formats.py:73
msgid ""
"This operation creates a directory, so you have to drag to a filer window on "
"the local machine"
msgstr "程序会建立一个新目录,因此必须在本机的窗口中拖放."

#: formats.py:79
msgid "'%s' already exists and is not a directory!"
msgstr "'%s' 已存在且并不是一个目录!"

#: formats.py:127
msgid "Create .%s archive"
msgstr "建立 .%s 压缩档"

